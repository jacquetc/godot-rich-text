[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]
linux.debug.x86_64 = "res://addons/godot_rich_text/bin/libgodot_rich_text.linux.debug.x86_64.so"
linux.release.x86_64 = "res://addons/godot_rich_text/bin/libgodot_rich_text.linux.release.x86_64.so"
windows.debug.x86_64 = "res://addons/godot_rich_text/bin/godot_rich_text.windows.debug.x86_64.dll"
windows.release.x86_64 = "res://addons/godot_rich_text/bin/godot_rich_text.windows.release.x86_64.dll"
macos.debug = "res://addons/godot_rich_text/bin/libgodot_rich_text.macos.debug.universal.dylib"
macos.release = "res://addons/godot_rich_text/bin/libgodot_rich_text.macos.release.universal.dylib"

[icons]
RichTextEdit = "res://addons/godot_rich_text/icons/RichTextEdit.svg"
RichTextView = "res://addons/godot_rich_text/icons/RichTextView.svg"